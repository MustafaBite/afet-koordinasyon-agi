{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "rewrites": [
    { "source": "/auth/:path*", "destination": "https://afet-koordinasyon-agi.onrender.com/auth/:path*" },
    { "source": "/api/:path*",  "destination": "https://afet-koordinasyon-agi.onrender.com/api/:path*" },
    { "source": "/requests/:path*", "destination": "https://afet-koordinasyon-agi.onrender.com/requests/:path*" },
    { "source": "/requests",   "destination": "https://afet-koordinasyon-agi.onrender.com/requests" },
    { "source": "/health",     "destination": "https://afet-koordinasyon-agi.onrender.com/health" },
    { "source": "/ws",         "destination": "https://afet-koordinasyon-agi.onrender.com/ws" },
    { "source": "/:path*",     "destination": "/index.html" }
  ]
}
